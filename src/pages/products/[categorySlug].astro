---
import Header from "@/components/Header.astro";
import ProductsSection from "@/components/ProductsSection.astro";
import Layout from "@/layouts/Layout.astro";
import {
  getCategories,
  getCategoryBySlug,
  getProductCardsByCategorySlug,
} from "@/lib/db";
import type { GetStaticPaths } from "astro";

export const getStaticPaths = (async () => {
  const categories = await getCategories();

  const result = categories.map((category) => ({
    params: { categorySlug: category.slug },
  }));
  return result;
}) satisfies GetStaticPaths;

const { categorySlug } = Astro.params;

const products = await getProductCardsByCategorySlug(categorySlug);

const category = await getCategoryBySlug(categorySlug);
---

<Layout>
  <Header title={category || ""} textWrap={false} />
  <ProductsSection products={products} />
</Layout>
