---
import Header from "@/components/Header.astro";
import ProductsSection from "@/components/ProductsSection.astro";
import Layout from "@/layouts/Layout.astro";
import {
  getCategories,
  getCategoryBySlug,
  getProductCardsByCategorySlug,
} from "@/lib/db";
import type { GetStaticPaths } from "astro";
import type { ProductCard } from "@/components/ProductsSection/Product";

export const getStaticPaths = (async () => {
  const categories = await getCategories();

  const result = categories.map((category) => ({
    params: { categorySlug: category.slug },
  }));
  return result;
}) satisfies GetStaticPaths;

const { categorySlug } = Astro.params;

const products: ProductCard[] = (
  await getProductCardsByCategorySlug(categorySlug)
).map(({ name, price, images }) => ({
  name,
  price,
  frontImage: images[0] || null,
  backImage: images[1] || null,
}));

const category = await getCategoryBySlug(categorySlug);
---

<Layout>
  <Header title={category?.name || ""} textWrap={false} />
  <ProductsSection products={products} />
</Layout>
