---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import ProductsSection from "@/components/ProductsSection.astro";
import { getCategoryById, getProductCards } from "@/lib/db";

const products = await getProductCards();
const productCards = products.map(({ name, price, images, slug }) => ({
  name,
  price,
  frontImage: images[0]
    ? import.meta.env.PUBLIC_API_URL + images[0]?.image
    : null,
  backImage: images[1]
    ? import.meta.env.PUBLIC_API_URL + images[1]?.image
    : null,
  categorySlug: "",
  productSlug: slug,
}));
for (let i = 0; i < productCards.length; i++) {
  productCards[i].categorySlug = (await getCategoryById(
    products[0].category,
  ))!.slug;
}
---

<Layout>
  <Header title="Products" textWrap={false} />
  <ProductsSection products={productCards} />
</Layout>
