---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import ProductsSection from "@/components/ProductsSection.astro";
import { getProductCards } from "@/lib/db";
import type { ProductCard } from "@/components/ProductsSection/Product";

const products: ProductCard[] = (await getProductCards()).map(
  ({ name, price, images }) => ({
    name,
    price,
    frontImage: images[0] || null,
    backImage: images[1] || null,
  }),
);
---

<Layout>
  <Header title="Products" textWrap={false} />
  <ProductsSection products={products} />
</Layout>
