---
import Header from "@/components/Header.astro";
import ProductsSection from "@/components/ProductsSection.astro";
import Layout from "@/layouts/Layout.astro";
import {
  getCategories,
  getCategoryById,
  getProductCardsByCategoryId,
} from "@/lib/db";
import type { GetStaticPaths } from "astro";

export const getStaticPaths = (async () => {
  const categories = await getCategories();

  const result = categories.map((category) => ({
    params: { categorieId: String(category.id) },
  }));
  return result;
}) satisfies GetStaticPaths;

const { categorieId } = Astro.params;

const products = await getProductCardsByCategoryId(Number(categorieId));

const category = await getCategoryById(Number(categorieId));
---

<Layout>
  <Header title={category?.categoryName || ""} textWrap={false} />
  <ProductsSection products={products} />
</Layout>
