---
import { links } from "@/lib/constants";
import HeroCarousel from "./HeroCarousel";

interface Image {
  src: string;
  alt: string;
  width: number;
  height: number;
}
const mockWidth = 300;
const mockHeight = 700;
const mockImages = new Array(5).fill("").map((_) => {
  return `https://picsum.photos/seed/${Math.floor(Math.random() * 1000)}/${mockWidth}/${mockHeight}`;
});
const images: Image[] = mockImages.map((image) => ({
  src: image,
  alt: image,
  width: mockWidth,
  height: mockHeight,
}));

const panels = images.map((image, index) => ({
  image: image,
  link: links[index],
}));
---

<HeroCarousel client:load panels={panels} />
